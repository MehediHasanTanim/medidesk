{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Django Backend",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd backend && .venv/bin/python manage.py runserver 0.0.0.0:8005"],
      "port": 8005
    },
    {
      "name": "React Frontend (Vite)",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:$PATH && cd frontend && npm run dev"],
      "port": 5177
    },
    {
      "name": "Celery Worker",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd backend && celery -A config worker --loglevel=info"],
      "port": null
    }
  ]
}
