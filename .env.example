# Copy this to .env and fill in the values
# Used by docker-compose for all services

# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DB_NAME=medidesk_dev
DB_USER=postgres
DB_PASSWORD=your-strong-password

# ── Redis / Celery ───────────────────────────────────────────────────────────
# These are overridden to use Docker service names in docker-compose.yml
# Only needed if running outside Docker
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── WhatsApp (Meta Business API) ─────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/PHONE_NUMBER_ID/messages
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_FROM_NUMBER=+8801XXXXXXXXX

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=MediDesk <noreply@medidesk.com>
